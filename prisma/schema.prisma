// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// --- THIS BLOCK WAS MISSING ---
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
// --- END MISSING BLOCK ---

generator client {
  provider = "prisma-client-js"
}

// --- THIS IS YOUR NEW, CORRECT USER MODEL ---
model User {
  id                Int      @id @default(autoincrement())
  phone             String   @unique
  name              String?
  role              String
  profilePictureUrl String?
  otp               String?  // <-- ADD THIS LINE: To store the 4-digit code
  otpExpiry         DateTime? // <-- ADD THIS LINE: To make sure the OTP expires
  isActive          Boolean  @default(true) // <-- ADD THIS LINE

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customerRides     Ride[]         @relation("CustomerRides")
  riderRides        Ride[]         @relation("RiderRides")
  refreshTokens     RefreshToken[]
}


// --- YOUR OTHER MODELS (Unchanged) ---
model Ride {
  id              Int      @id @default(autoincrement())
  vehicle         String   @db.VarChar(20)
  distance        Float
  pickupAddress   String
  pickupLatitude  Float
  pickupLongitude Float
  dropAddress     String
  dropLatitude    Float
  dropLongitude   Float
  fare            Float
  commission      Float    @default(0) // <-- ADD THIS LINE
  review    Review? // A ride can have one review (optional)

  customer        User     @relation("CustomerRides", fields: [customerId], references: [id])
  customerId      Int
  rider           User?    @relation("RiderRides", fields: [riderId], references: [id])
  riderId         Int?
  status          String   @default("SEARCHING_FOR_RIDER") @db.VarChar(30)
  otp             String?  @db.VarChar(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  isValid   Boolean  @default(true)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  costPerKm Float
  icon      String   // We store the icon name as a string
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Add this new model to your schema.prisma file

// Replace the old PromoCode model with this one

model PromoCode {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  usageLimit     Int      @default(0)
  totalUsed      Int      @default(0)
  expiryDate     String
  // --- THIS IS THE FIX ---
  // The field should be named discountValue, not discount
  discountValue  Float
  // --- END FIX ---
  discountType   String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Float    // e.g., 4.5
  comment   String?
  rideId    Int      @unique // A ride can only have one review
  ride      Ride     @relation(fields: [rideId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentType {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  requiresExpiry  Boolean  @default(false)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Setting {
  key   String @id // The unique key, e.g., "WEBSITE_NAME"
  value String // The value for that key
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // e.g., "All Users", "All Drivers"
  title     String
  message   String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}